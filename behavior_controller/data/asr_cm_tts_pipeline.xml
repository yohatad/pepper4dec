<?xml version="1.0"?>
<!--
  asr_cm_tts_pipeline.xml
  ASR → Conversation Manager → SpeechWithFeedback  (testing pipeline)

  A minimal 3-step loop for validating the full speech pipeline end-to-end:
    1. SpeechRecognition    – listen for up to 20 s
    2. ConversationManager  – RAG + LLM; writes {llm_response}, {intent},
                              and {confidence} to the blackboard.
                              The LLM embeds NAOqi ALTextToSpeech prosody tags
                              (e.g. \pau=\, \rspd=\, \vct=\) in the response
                              for natural-sounding speech.
    3. SpeechWithFeedback   – calls /naoqi_driver/speech_with_feedback action;
                              ALAnimatedSpeech interprets the prosody tags AND
                              drives body-language gestures automatically
                              (body_language_mode = "contextual")

  NOTE: SpeechWithFeedback (ALAnimatedSpeech / ALTextToSpeech) is used here
        so that NAOqi prosody tags embedded by the LLM are interpreted correctly.
        ElevenLabs (TTS node) would read them as literal text.

  Intent routing belongs in scenario-specific trees (e.g. lab_tour.xml).
  Here, {intent} and {confidence} are captured but not acted on — useful
  for verifying that the LLM is classifying correctly during development.
-->
<root BTCPP_format="4">

  <BehaviorTree ID="asr_cm_tts_pipeline">
    <Repeat num_cycles="-1">
      <Sequence>

        <!-- ── Step 1: Wait for engagement (optional) ───────────────────── -->
        <!-- <IsMutualGazeDiscovered timeout="30.0"/> -->

        <!-- ── Step 2: Listen → Think → Speak ───────────────────────────── -->
        <Fallback>

          <!-- Happy path: speech heard → LLM responds → robot speaks + gestures -->
          <Sequence>
            <SpeechRecognition
              wait="20.0"
              transcription="{user_speech}"
              status="{asr_status}"/>

            <ConversationManager
              prompt="{user_speech}"
              response="{llm_response}"
              intent="{intent}"
              confidence="{confidence}"
              status="{cm_status}"/>

            <!-- SpeechWithFeedback passes the response (with embedded prosody tags)
                 to ALAnimatedSpeech, which interprets \pau=\, \rspd=\, \vct=\ etc.
                 and adds contextual body-language gestures automatically. -->
            <SpeechWithFeedback
              say="{llm_response}"
              body_language_mode="contextual"/>
          </Sequence>

          <!-- Fallback: no speech heard → prompt and retry -->
          <SpeechWithFeedback
            say="Any questions?"
            body_language_mode="contextual"/>

        </Fallback>
      </Sequence>
    </Repeat>
  </BehaviorTree>

</root>
