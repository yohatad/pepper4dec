<package format="3">
  <name>pepper_navigation</name>
  <version>0.0.0</version>
  <description>TODO: Package description</description>
  <maintainer email="yohatad000@gmail.com">yoha</maintainer>
  <license>TODO: License declaration</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>nav2_bringup</depend>
  <depend>nav2_map_server</depend>
  <depend>nav2_amcl</depend>
  <depend>nav2_controller</depend>
  <depend>nav2_planner</depend>
  <depend>nav2_behaviors</depend>
  <depend>nav2_bt_navigator</depend>
  <depend>nav2_lifecycle_manager</depend>
  <depend>nav2_costmap_2d</depend>
  <depend>rclcpp</depend>
  <depend>rclcpp_action</depend>
  <depend>nav_msgs</depend>
  <depend>geometry_msgs</depend>
  <depend>visualization_msgs</depend>
  <depend>std_srvs</depend>
  <depend>nav2_msgs</depend>

  <!-- launched by inclusion (pepper_nav2_bringup.launch.py), not linked.
       pepper_slam supplies rtabmap_realsense.launch.py, which this package
       runs in localization mode to get map -> odom_level and /map. The
       dependency is one-way: pepper_slam never depends on pepper_navigation. -->
  <exec_depend>pepper_slam</exec_depend>
  <exec_depend>fast_lio</exec_depend>

  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
