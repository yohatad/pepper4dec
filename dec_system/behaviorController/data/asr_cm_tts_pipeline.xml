<?xml version="1.0"?>
<!--
  asr_cm_tts_pipeline.xml
  ASR → Conversation Manager → TTS  (testing pipeline)

  A minimal 3-step loop for validating the full speech pipeline end-to-end:
    1. SpeechRecognition  – listen for up to 7 s
    2. ConversationManager – RAG + LLM; streams sentences to /tts/input;
                             writes {intent} and {confidence} to the blackboard
    3. TTS                – calls /tts action server; blocks until playback done

  Intent routing belongs in scenario-specific trees (e.g. lab_tour.xml).
  Here, {intent} and {confidence} are captured but not acted on — useful
  for verifying that the LLM is classifying correctly during development.
-->
<root BTCPP_format="4">

  <BehaviorTree ID="asr_cm_tts_pipeline">
    <Repeat num_cycles="-1">
      <Sequence>

        <!-- ── Step 1: Wait for engagement (optional) ───────────────────── -->
        <!-- <IsMutualGazeDiscovered timeout="30.0"/> -->

        <!-- ── Step 2: Listen → Think → Speak ───────────────────────────── -->
        <Fallback>

          <!-- Happy path: speech heard → LLM responds → TTS speaks -->
          <Sequence>
            <SpeechRecognition
              wait="7.0"
              transcription="{user_speech}"
              status="{asr_status}"/>

            <ConversationManager
              prompt="{user_speech}"
              response="{llm_response}"
              intent="{intent}"
              confidence="{confidence}"
              status="{cm_status}"/>

            <TTS
              text="{llm_response}"
              status="{tts_status}"
              message="{tts_message}"/>
          </Sequence>

          <!-- Fallback: no speech heard → prompt and retry -->
          <TTS
            text="I didn't catch that. Could you please repeat?"
            status="{tts_status}"
            message="{tts_message}"/>

        </Fallback>
      </Sequence>
    </Repeat>
  </BehaviorTree>

</root>
