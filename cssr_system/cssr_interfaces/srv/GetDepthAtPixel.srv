# Request
# Mode 1: Single point with radius
int32 center_x
int32 center_y
int32 radius        # Radius in pixels (0 for single point)

# Mode 2: Multiple points with radii
int32[] centers_x
int32[] centers_y
int32[] radii       # Can be same radius for all or individual

---
# Response
bool success
string message

# Single point/circle response
float32 depth           # Depth at center or mean depth in circle
float32 min_depth      # Min depth in circle
float32 max_depth      # Max depth in circle
float32 std_depth      # Standard deviation
float32 confidence     # Ratio of valid pixels

# Multiple points response
float32[] depths       # Depth at each point/circle
float32[] confidences  # Confidence for each measurement